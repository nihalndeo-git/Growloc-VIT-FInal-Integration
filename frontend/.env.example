# MongoDB
MONGODB_URI=mongodb://localhost:27017/growloc

# MinIO (S3-compatible). Create bucket `growloc` (or set MINIO_BUCKET) in MinIO console.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Optional: defaults to "growloc"
# MINIO_BUCKET=growloc
# Optional: public base for object URLs if it differs from MINIO_ENDPOINT (e.g. behind a proxy)
# MINIO_PUBLIC_BASE_URL=http://localhost:9000

# AI service (FastAPI)
AI_SERVICE_URL=http://localhost:8001
